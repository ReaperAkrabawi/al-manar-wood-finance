{
  "expo": {
    "name": "Al Manar Wood Finance",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "almanar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#180D04"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.almanar.woodfinance"
    },
    "android": {
      "package": "com.almanar.woodfinance",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#180D04"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "cb3252a6-bdd1-4048-8d3f-55b66ceaf277"
      }
    }
  }
}
